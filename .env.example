# ── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development           # development | production
SECRET_KEY=change-me-in-prod  # used for webhook signature verification
LOG_LEVEL=INFO

# ── Anthropic / Claude ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ── Database ─────────────────────────────────────────────────────────────────
# Dev: leave empty to use SQLite (meetingmind.db)
# Prod (Railway): set to postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=

# ── Jira ─────────────────────────────────────────────────────────────────────
JIRA_SERVER_URL=https://yourcompany.atlassian.net
JIRA_USER_EMAIL=you@company.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=ENG                # default project for tickets
JIRA_ISSUE_TYPE=Task                # Task | Story | Bug

# ── Gmail ────────────────────────────────────────────────────────────────────
# Option A: OAuth2 service account JSON path (recommended for prod)
GMAIL_SERVICE_ACCOUNT_JSON=
# Option B: SMTP fallback (simpler dev setup)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM_NAME=MeetingMind

# ── Slack ────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_DEFAULT_CHANNEL=#meeting-summaries

# ── Zoom ─────────────────────────────────────────────────────────────────────
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET_TOKEN=   # for webhook request validation

# ── Google Meet ───────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=
GOOGLE_WORKSPACE_ADMIN_EMAIL=   # for domain-wide delegation
